{
  "experiment_name": "yacht_1080p120_phase1",
  "network": {
    "host": "192.168.3.203",
    "port": 5004,
    "rtp_payload_type": 96,
    "clock_rate": 90000,
    "jitterbuffer_latency_ms": 50,
    "mtu": 1300
  },
  "video_input": {
    "path": "videos/YachtRide_1920x1080_120fps_420_8bit_YUV.yuv",
    "width": 1920,
    "height": 1080,
    "source_framerate": 120,
    "framerate": 120,
    "format": "i420"
  },
  "encoder": {
    "codec": "h264",
    "bitrate_kbps": 8000,
    "speed_preset": "veryfast",
    "tune": "zerolatency",
    "key_int_max": 120,
    "bframes": 0,
    "threads": 0,
    "software_h264_encoder": "x264enc",
    "software_h265_encoder": "x265enc",
    "hardware_encoder_placeholder": {
      "enabled": false,
      "element": "v4l2h264enc",
      "notes": "占位符。不同平台可能需要替换为 v4l2h264enc, v4l2slh264enc, vaapih264enc, nvh264enc, mpph264enc 等。当前未测试。"
    }
  },
  "receiver": {
    "mode": "full_stats",
    "decode": true,
    "sink": "appsink",
    "sync": false,
    "output_root": "output",
    "save_resolved_config": true,
    "save_run_info": true,
    "appsink_max_buffers": 32,
    "appsink_drop": true,
    "post_decode_queue_max_buffers": 8,
    "csv_flush_interval": 60,
    "probe_sink_sync": false,
    "software_h264_decoder": "avdec_h264",
    "software_h265_decoder": "avdec_h265",
    "hardware_decoders": {
      "h264": "v4l2h264dec",
      "h265": "v4l2h265dec"
    },
    "hardware_decoder_placeholder": {
      "enabled": true,
      "element": "auto",
      "notes": "默认按 codec 自动选择 receiver.hardware_decoders 中的硬解元素；未配置时回退到 v4l2h264dec / v4l2h265dec。不同平台可替换为 mppvideodec, vaapih264dec 等。"
    }
  },
  "receiver_load": {
    "enabled": false,
    "startup_delay_sec": 2,
    "workdir": ".",
    "binary": "./vulkan_mem_press/vk_memstress",
    "args": [
      "--mb",
      "512",
      "--mode",
      "rdwr",
      "--stride",
      "16",
      "--iters",
      "200",
      "--chunk-iters",
      "40",
      "--einv",
      "128",
      "--wg",
      "4096",
      "--seconds",
      "45",
      "--spv",
      "./vulkan_mem_press/memstress.spv"
    ],
    "log_stdout": true
  },
  "stall_thresholds_ms": {
    "mode": "frame_intervals",
    "minor": 50,
    "major": 200,
    "minor_frame_intervals": 1.5,
    "major_frame_intervals": 3.0
  }
}